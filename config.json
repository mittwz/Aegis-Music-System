{
  // Project metadata used in logs and documentation.
  "branding": {
    "name": "Aegis Music System",
    "tagline": "Adaptive music direction for Dota 2 and Spotify",
    "repo": "aegis-music-system",
    "accent": "radiant-green"
  },

  // Default language for documentation and log wording.
  // Alternatives you may keep for your own notes: "pt-BR"
  "language": "en",

  // Choose which playlist profile is active.
  // Alternatives: "default", "custom_user_electronic", "copyrighted_mainstream"
  "active_profile": "default",

  // Local HTTP server used by Dota GSI.
  "server": {
    "host": "127.0.0.1",
    "port": 3000,
    "auth_token": "aegis_music_system"
  },

  // Spotify behavior.
  "spotify": {
    "enabled": true,
    "playlist_switching_enabled": true,
    "queue_enabled": false,
    "pause_enabled": false,
    "shuffle": true,
    "cooldown_seconds": 18,
    "random_start": false,
    "victory_track_uri": null,
    "defeat_track_uri": null
  },

  // Audio behavior.
  "audio": {
    // Base target volume before master gain is applied.
    "base_volume": 45,

    // Global loudness multiplier for the entire system.
    // This is the main day-to-day volume control.
    // Suggested values:
    // 70  = quieter / headphones
    // 100 = neutral
    // 120 = louder speakers
    // 140 = very aggressive output
    "master_gain_percent": 100,

    // Alternatives: "standard", "cinema"
    "mode": "cinema",

    // Fade speed per tick. Lower = smoother, higher = faster.
    "fade_step": 4,

    // Main loop speed.
    "tick_interval_seconds": 1.0,

    // HP thresholds used by the state tracker.
    "low_hp_threshold": 0.28,
    "critical_hp_threshold": 0.14,

    // How often to repeat the 'still waiting for payload' warning.
    "payload_warning_interval_seconds": 60.0,

    // How long cinema mode keeps dramatic states alive.
    "cinema_hold_seconds": {
      "teamfight": 6.0,
      "low_hp": 3.5,
      "dead": 4.0
    }
  },

